# Multi-organization platform (copy to .env; never commit .env)

APP_ENV=development
APP_MODE=control_plane
APP_NAME=SanghSampark

# Subtle teal accents on forms, buttons, tables (set false to revert)
SUBTLE_ACCENT=true

# Public URL (no trailing slash) — must match the exact URL users open in the browser (including /public if in the path)
APP_URL=http://localhost/szvs-tenant/public
ASSET_URL=http://localhost/szvs-tenant

# Outbound email — Techwise hosting (production) or Gmail (local dev)
# Production (shared hosting): mail.techwise.co.in port 465 SSL
MAIL_FROM=office@techwise.co.in
MAIL_FROM_NAME=SanghSampark
SMTP_HOST=mail.techwise.co.in
SMTP_PORT=465
SMTP_SECURE=ssl
SMTP_USER=office@techwise.co.in
SMTP_PASS=your-email-account-password
# Optional: PHP CLI for background email jobs (WAMP Apache uses httpd.exe as PHP_BINARY)
# PHP_CLI_PATH=C:/wamp64/bin/php/php8.3.14/php.exe

# Keep users signed in on mobile/PWA (seconds, default 30 days)
# SESSION_LIFETIME=2592000

DATABASE_HOST=127.0.0.1
DATABASE_PORT=3306
DATABASE_NAME=szvs
DATABASE_USER=root
DATABASE_PASSWORD=

# Optional legacy single-org hint (session org is used at runtime)
# ORG_CODE=DEM
# ORGANIZATION_ID=1

# Web push (PWA / browser notifications). Generate keys: php bin/generate-vapid-keys.php
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_SUBJECT=mailto:admin@example.com

# Member → admin session chat widget (set false to disable without removing code)
# Temp off — set true to re-enable member ↔ admin chat
MEMBER_ADMIN_CHAT=false

# Daily tithi direct web push to all members (no in-app/DB storage; run at 07:00 APP_TIMEZONE)
DAILY_TITHI_NOTIFICATIONS=true
APP_TIMEZONE=Asia/Kolkata
DAILY_TITHI_HOUR=7
DAILY_TITHI_MINUTE=0
# Allow send if cron runs within this many minutes of the target time
DAILY_TITHI_WINDOW_MINUTES=30

# Selected tithi reminders at 23:00 (push only — no in-app DB rows)
SCHEDULED_TITHI_REMINDERS=true
SCHEDULED_TITHI_HOUR=23
SCHEDULED_TITHI_MINUTE=0
SCHEDULED_TITHI_WINDOW_MINUTES=30
# Comma-separated tithi names (must match panchang CSV). Edit config/tithi_reminders.php or set here:
# TITHI_REMINDER_TITHIS=Pancham,Atham,Chaudas,Poonam,Amas

# Push (no DB) when an org calendar day is created and 23:00 the day before it starts
CALENDAR_DAY_NOTIFICATIONS=true
