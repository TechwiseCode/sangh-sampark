# Production server — copy to project root on server as ".env"
# Update DATABASE_* and SMTP_PASS. See deploy/env/README.txt

APP_ENV=production
APP_MODE=control_plane
APP_NAME=SanghSampark
SUBTLE_ACCENT=true

# Must match the exact URL users open in the browser
APP_URL=https://techwise-apps.com/sanghsampark/public
ASSET_URL=https://techwise-apps.com/sanghsampark

# Gmail SMTP (forgot password, new member invite)
MAIL_FROM=sanghsamparkadmin@gmail.com
MAIL_FROM_NAME=SanghSampark
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=tls
SMTP_USER=sanghsamparkadmin@gmail.com
SMTP_PASS=PASTE_GMAIL_APP_PASSWORD_HERE

# --- Fill from your hosting panel (cPanel / Plesk) ---
DATABASE_HOST=localhost
DATABASE_PORT=3306
DATABASE_NAME=YOUR_SERVER_DB_NAME
DATABASE_USER=YOUR_SERVER_DB_USER
DATABASE_PASSWORD=YOUR_SERVER_DB_PASSWORD

SESSION_NAME=SANGHSAMPARK_SESS
# SESSION_LIFETIME=2592000

MEMBER_ADMIN_CHAT=false

APP_TIMEZONE=Asia/Kolkata
DAILY_TITHI_NOTIFICATIONS=true
DAILY_TITHI_HOUR=7
DAILY_TITHI_MINUTE=0
DAILY_TITHI_WINDOW_MINUTES=30
SCHEDULED_TITHI_REMINDERS=true
SCHEDULED_TITHI_HOUR=23
SCHEDULED_TITHI_MINUTE=0
SCHEDULED_TITHI_WINDOW_MINUTES=30
CALENDAR_DAY_NOTIFICATIONS=true

# Web push — on server run: php bin/generate-vapid-keys.php then paste keys here
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_SUBJECT=mailto:sanghsamparkadmin@gmail.com
